{
  "openapi": "3.1.0",
  "info": {
    "title": "ForexMind API",
    "description": "Multi-agent Forex signal generation pipeline. Endpoints: generate-signal, health, pipeline-status, signal-accuracy.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local development"
    }
  ],
  "paths": {
    "/generate-signal": {
      "post": {
        "summary": "Generate Signal",
        "description": "Run the full five-agent LangGraph pipeline for the given pair.\nAccepts pair in JSON body {\"pair\": \"AUDUSD\"} or query param ?pair=AUDUSD.",
        "operationId": "generate_signal_generate_signal_post",
        "parameters": [
          {
            "name": "pair",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Pair"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/GenerateSignalRequest"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Req"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateSignalResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health",
        "description": "Return current status of all pipeline sources from pipeline_health (latest per source).",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/pipeline-status": {
      "get": {
        "summary": "Pipeline Status",
        "description": "Return last 24 hours of health log entries.",
        "operationId": "pipeline_status_pipeline_status_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Pipeline Status Pipeline Status Get"
                }
              }
            }
          }
        }
      }
    },
    "/signal-accuracy": {
      "get": {
        "summary": "Signal Accuracy",
        "description": "Return win rate from signal_outcomes (resolved signals only).",
        "operationId": "signal_accuracy_signal_accuracy_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Signal Accuracy Signal Accuracy Get"
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Root",
        "description": "Root endpoint.",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Root  Get"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GenerateSignalRequest": {
        "properties": {
          "pair": {
            "type": "string",
            "title": "Pair",
            "default": "AUD/USD"
          }
        },
        "type": "object",
        "title": "GenerateSignalRequest"
      },
      "GenerateSignalResponse": {
        "properties": {
          "pair": {
            "type": "string",
            "title": "Pair"
          },
          "macro_sentiment": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Macro Sentiment"
          },
          "technical_setup": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Technical Setup"
          },
          "user_patterns": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "User Patterns"
          },
          "coach_advice": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Coach Advice"
          },
          "final_signal": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Final Signal"
          },
          "should_trade": {
            "type": "boolean",
            "title": "Should Trade"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          }
        },
        "type": "object",
        "required": [
          "pair",
          "macro_sentiment",
          "technical_setup",
          "user_patterns",
          "coach_advice",
          "final_signal",
          "should_trade",
          "error"
        ],
        "title": "GenerateSignalResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}